            "paragraphs": [
                {
                    "sentence": "前条の場合のほか、組合員は、次に掲げる事由によって脱退する。",
                    "items": [
                        "死亡",
                        "破産手続開始の決定を受けたこと。",
                        "後見開始の審判を受けたこと。",
                        "除名"
                    ]
                }
            ]
        }
